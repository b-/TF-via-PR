{
  "name": "tf-via-pr",
  "description": "Plan and apply Terraform/OpenTofu via PR automation.",
  "homepage": "https://github.com/op5dev/tf-via-pr",
  "repository": "github:op5dev/tf-via-pr",
  "type": "commonjs",
  "license": "Apache-2.0",
  "private": true,
  "author": {
    "name": "Rishav Dhar",
    "url": "https://www.rdhar.dev"
  },
  "bugs": {
    "url": "https://github.com/op5dev/tf-via-pr/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/op5dev"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "bun build src/main.ts --target=node --format=cjs --minify --sourcemap=none --outfile=dist/index.js",
    "build:check": "bun run build && git diff --exit-code --stat -- dist/",
    "format": "bunx prettier --write src __tests__ package.json tsconfig.json",
    "format:check": "bunx prettier --check src __tests__ package.json tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/artifact": "6.2.1",
    "@actions/core": "3.0.1",
    "@actions/exec": "3.0.0",
    "@actions/github": "9.1.1"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/node": "25.9.4",
    "prettier": "3.8.4",
    "typescript": "6.0.3"
  }
}
